{
  "name": "@sportsxon/cli",
  "version": "0.1.0",
  "description": "Dual-mode CLI for FIFA World Cup 2026 data (via MCP) and Kalshi/Polymarket prediction-market trading — a rich React-Ink TUI for humans and a scriptable, agent-friendly headless mode for Claude Code and other agents.",
  "type": "module",
  "bin": {
    "sportsxon": "bin/sportsxon.mjs",
    "sx": "bin/sportsxon.mjs"
  },
  "files": [
    "dist",
    "bin",
    "skills",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "world-cup",
    "world-cup-2026",
    "cli",
    "tui",
    "ink",
    "mcp",
    "model-context-protocol",
    "kalshi",
    "polymarket",
    "prediction-markets",
    "trading",
    "paper-trading",
    "claude",
    "agent"
  ],
  "author": "GagnDeep",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GagnDeep/sportsxon-cli.git"
  },
  "homepage": "https://sportsxon.com/en/mcp",
  "bugs": {
    "url": "https://github.com/GagnDeep/sportsxon-cli/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "ink": "^5.1.0",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "picocolors": "^1.1.1",
    "react": "^18.3.1",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "@polymarket/clob-client": "^5.8.1",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.12",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
